# =============================================
# Ollama Agent System Configuration
#
# Copy this file to .env and modify for your setup:
#   cp .env.example .env
#   nano .env  # Edit with your models and settings
#
# =============================================

# ------ Connection Settings ------

# URL of the Ollama server
# Default: http://localhost:11434
# For remote Ollama: http://your-server:11434
OLLAMA_HOST=http://localhost:11434

# Timeout for API requests (seconds)
# Increase if you get "Request timed out" errors
REQUEST_TIMEOUT=240

# ------ Model Mappings ------

# The system uses these aliases in workflow YAML files:
#   - REASONING_MODEL  (for analyst, architect, reviewer steps)
#   - CODING_MODEL     (for developer/code generation steps)
#   - GENERAL_MODEL    (optional: fallback for general tasks)
#
# Recommended models:
#   REASONING_MODEL=llama3.1:8b or mistral-nemo:12b
#   CODING_MODEL=qwen2.5-coder:7b or codestral-latest:latest
# =============================================
REASONING_MODEL=llama3.1:8b
coding_model=qwen2.5-coder:7b
GENERAL_MODEL=llama3.1:8b

# ------ Vector Database Configuration ------

# Vector database backend: chroma, pinecone, or qdrant
VECTOR_DB_TYPE=chroma

# ChromaDB persistence directory (empty string to disable)
CHROMA_PERSIST_DIR=./data/chroma_db

# Embedding model for text chunk embedding
EMBEDDING_MODEL=all-MiniLM-L6-v2

# Pinecone configuration (uncomment if using):
# PINECONE_API_KEY=your-api-key-here

# Qdrant configuration (uncomment if using):
# QDRANT_URL=http://localhost:6333
# QDRANT_PORT=6333

# ------ Optional Settings ------

# Log level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# Enable vector context injection globally
ENABLE_VECTOR_CONTEXT=true
